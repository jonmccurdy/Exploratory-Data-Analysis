library(openintro)
library(dplyr)
library(tidyr)
library(ggplot2)
sampling_distribution <- function(data, sample_size, n_samples, FUN){
sample_dist <- c()
for(i in 1:n_samples){
sample <- sample(data, size=sample_size, replace=TRUE)
sample_stat <- FUN(sample)
sample_dist[i] <- sample_stat
sample_dist[i] <- sample_stat}
sampling_distribution <- function(data, sample_size, n_samples, FUN){
sample_dist <- c()
for(i in 1:n_samples){
sample <- sample(data, size=sample_size, replace=TRUE)
sample_stat <- FUN(sample)
sample_dist[i] <- sample_stat
}
return(sample_dist)
}
