library(openintro)
library(dplyr)
data(present)
head(present)
present$More <- ifelse(present$boys > present$girls, "Boys", "Girls")
present <- present |> mutate(diff = boys - girls)
present <- present |> mutate(decade = factor(
ifelse(year > 1940 & year < 1949,"40's",
ifelse(year > 1950 & year < 1959, "50's",
ifelse(year > 1960 & year < 1969,"60's",
ifelse(year > 1970 & year < 1979, "70's",
ifelse(year > 1980 & year < 1989, "80's",
ifelse(year > 1990 & year < 1999, "90's",
"00's")))))), ordered = TRUE,
levels = c("40's", "50's","60's", "70's", "80's", "90's", "00's")))
present |> group_by(decade) |>
summarise(observations = n(), min_diff = min(diff), mean_diff = mean(diff),
max_diff = max(diff)) |>
ungroup()
