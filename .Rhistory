portfolio_performance <- master_results %>%
inner_join(master_data_stocks_clean, by = c("date", "ticker")) %>%
# 1. Calculate the total return over that 5-day window
mutate(total_horizon_return = (horizon_close - close) / close) %>%
# 2. IMPORTANT: Shift the date 5 days forward.
# This shows the wealth on the day the trade is CLOSED, not opened.
mutate(realization_date = date + 5) %>%
group_by(realization_date) %>%
summarize(model_return = mean(total_horizon_return, na.rm = TRUE)) %>%
# 3. Calculate cumulative growth starting from the first realization
arrange(realization_date) %>%
mutate(model_cum = cumprod(1 + model_return)) %>%
rename(date = realization_date)
benchmark_performance <- master_data_SP500IT_clean %>%
mutate(realization_date = date + 5) %>%
mutate(bench_return = (horizon_close - close) / close) %>%
group_by(realization_date) %>%
summarize(bench_return = mean(bench_return, na.rm = TRUE)) %>%
arrange(realization_date) %>%
mutate(bench_cum = cumprod(1 + bench_return)) %>%
rename(date = realization_date)
comparison_df <- inner_join(portfolio_performance, benchmark_performance, by = "date")
ggplot(comparison_df, aes(x = date)) +
geom_line(aes(y = model_cum, color = "ML Trading Model"), size = 1.2) +
geom_line(aes(y = bench_cum, color = "S&P 500 IT (Benchmark)"), linetype = "dashed", size = 1) +
scale_color_manual(values = c("ML Trading Model" = "#2E8B57",
"S&P 500 IT (Benchmark)" = "#7F7F7F")) +
labs(title = "Relative Performance: ML Model vs. Sector Benchmark",
subtitle = "March 2026 Performance Analysis (N = 73 Tickers)",
y = "Portfolio Value (Growth of $1)",
x = "March 2026",
color = "Strategy Type") +
theme_minimal(base_size = 14) + # Larger text for the projector
theme(legend.position = "bottom")
ggplot(master_results, aes(x = date, y = ticker, fill = predicted_return)) +
geom_tile() +
scale_fill_gradient2(low = "red", mid = "white", high = "blue") +
theme_minimal() +
labs(title = "Model Prediction Heatmap (March 2026)",
subtitle = "Visualizing signals across 73 IT Tickers",
fill = "Pred. Return")
ticker_analysis <- master_results %>%
inner_join(master_data_stocks_clean, by = c("date", "ticker")) %>%
mutate(sq_error = (predicted_return - ((horizon_close - close)/close))^2) %>%
group_by(ticker) %>%
summarize(
avg_mse = mean(sq_error, na.rm = TRUE),
total_stock_return = sum((horizon_close - close)/close, na.rm = TRUE)
) %>%
arrange(avg_mse)
# stock with lowest error
