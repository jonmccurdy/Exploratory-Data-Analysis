library(dplyr)
library(tidyr)
library(ggplot2)
plot_data <- results |>
mutate(
buy_status = ifelse(allocation > 0, "Bought", "Not Bought")
) |>
pivot_longer(
cols = c(close, horizon_close),
names_to = "price_type",
values_to = "price"
) |>
mutate(
price_type = factor(price_type,
levels = c("close", "horizon_close"),
labels = c("Start", "Close"))
)
ggplot(plot_data,
aes(x = price_type,
y = price,
group = interaction(date, ticker),
color = buy_status)) +
geom_line(alpha = 0.8) +
geom_point(size = 2.5) +
facet_wrap(~ date) +
labs(
x = "",
y = "Price",
color = "",
title = "Start and Close Prices for Each Stock"
) +
theme_minimal() +
theme(
legend.position = "bottom"
)
library(dplyr)
library(ggplot2)
top_4_tickers <- results |>
group_by(ticker) |>
summarise(total_allocation = sum(allocation, na.rm = TRUE), .groups = "drop") |>
slice_max(order_by = total_allocation, n = 4) |>
pull(ticker)
plot_data <- results |>
filter(ticker %in% top_4_tickers) |>
mutate(
buy_status = ifelse(allocation > 0, "Bought", "Not Bought")
)
ggplot(plot_data, aes(x = date)) +
geom_segment(aes(xend = date,
y = close,
yend = horizon_close,
color = buy_status),
linewidth = 0.9,
alpha = 0.8) +
geom_point(aes(y = close, color = buy_status), size = 2) +
geom_point(aes(y = horizon_close, color = buy_status), size = 2) +
facet_wrap(~ ticker, ncol = 1, scales = "free_y") +
labs(
x = "Start Date",
y = "Price",
color = "",
title = "Start and Close Prices for the 4 Highest-Allocation Stocks"
) +
theme_minimal() +
theme(
legend.position = "bottom"
)
library(dplyr)
library(ggplot2)
top_4_tickers <- results |>
group_by(ticker) |>
summarise(total_allocation = sum(allocation, na.rm = TRUE), .groups = "drop") |>
slice_max(order_by = total_allocation, n = 4) |>
pull(ticker)
plot_data <- results |>
filter(ticker %in% top_4_tickers) |>
mutate(
pct_change = 100 * (horizon_close - close) / close,
buy_status = ifelse(allocation == 0, "Not Bought", "Bought")
)
plot_one_stock <- function(stock_name) {
stock_df <- plot_data |>
filter(ticker == stock_name)
ggplot(stock_df, aes(x = date, color = buy_status)) +
geom_hline(yintercept = 0, linetype = "dashed") +
geom_segment(aes(xend = date, y = 0, yend = pct_change),
linewidth = 1) +
geom_point(aes(y = 0), color = "black", size = 1.5) +
geom_point(aes(y = pct_change), size = 2.5) +
scale_color_manual(values = c("Bought" = "steelblue", "Not Bought" = "grey70")) +
labs(
title = stock_name,
x = "Start Date",
y = "Percent Change"
) +
theme_minimal() +
theme(legend.position = "bottom")
}
plots <- lapply(top_4_tickers, plot_one_stock)
plots[[1]]
plots[[2]]
plots[[3]]
plots[[4]]
