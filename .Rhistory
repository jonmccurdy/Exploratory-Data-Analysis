sampling_distribution <- function(x, sample_size=30, n_samples=1000, FUN=mean){
sample_dist <- c()
for(i in 1:n_samples){
sample <- sample(x, size=sample_size, replace=TRUE)
sample_stat <- FUN(sample, na.rm=TRUE)
sample_dist[i] <- sample_stat
}
return(tibble(stat=sample_dist))
}
sampling_distribution_bivariate <- function(data, x, y, sample_size = 30, n_samples = 1000, FUN = cor){
sample_dist <- c()
for(i in 1:n_samples){
current_sample <- data |> slice_sample(n = sample_size, replace = TRUE)
sample_stat <- FUN(current_sample[[x]], current_sample[[y]])
sample_dist[i] <- sample_stat
}
return(tibble(stat=sample_dist))
}
