start_date = "2026-03-01"
end_date = "2026-04-09"
sector = "Information Technology"
# updated list of S&P 500 stocks - from GitHub
url <- "https://raw.githubusercontent.com/datasets/s-and-p-500-companies/main/data/constituents.csv"
# to read and converge list into a data frame
sp500_full_list <- readr::read_csv(url , show_col_types = TRUE)
# filter for the IT sector (68 companies)
sector_list <- sp500_full_list |>
dplyr::filter(`GICS Sector` == sector)
# list of tickers for tech stocks
symbols <- sector_list$Symbol
# To iterate through symbol_tech_list --> to retrieve stock data using yahoofinancer commands
rows <- vector("list", length(symbols))
for(i in seq_along(symbols)){
sym <- symbols[i]
try({
stock <- quantmod::getSymbols(
sym,
src = "yahoo",
from = start_date,
to = end_date,
auto.assign = FALSE
)
df <- data.frame(
date = zoo::index(stock),
coredata(stock)
)
colnames(df) <- c("date", "open",
"high",
"low",
"close",
"volume",
"adjusted")[1:ncol(df)]
rows[[i]] <- df %>%
dplyr::mutate(symbol = sym)
}, silent = TRUE)
# to remove adj close
master_data <- dplyr::bind_rows(rows) |>
dplyr::select(-contains("Adjusted"))
# to get the S&P data
sp500_IT <- quantmod::getSymbols("^SP500-45",
src = "yahoo",
from = "2026-03-01",
to ="2026-04-09",
auto.assign = FALSE)
df_sp500_IT <- data.frame(date = zoo::index(sp500_IT), coredata(sp500_IT))
# to concatenate data
master_data_2 <- list(
stocks = master_data,
index = df_sp500_IT)
}
