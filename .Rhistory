library(primes)
install.packages("primes")
library(primes)
values <- c()
length(values)
is_prime(4)
is_prime(5)
return(sum(values))
sum_primes_to_nth() <- function(n){
values <- c()
i <- 1
check <- 1
while(length(values) <= n){
if(is_prime(check)) {values[i] <- check}
check <- check + 1
}
return(sum(values))
}
sum_primes_to_nth <- function(n){
values <- c()
i <- 1
check <- 1
while(length(values) <= n){
if(is_prime(check)) {values[i] <- check}
check <- check + 1
}
return(sum(values))
}
sum_primes_to_nth(10)
