summarise(avg_score = mean(average))
# Compute the average numeric score for each grade level across all subjects.
course_tidy |>
group_by(year) |>
summarise(avg_score = mean(average))
# Compute the average numeric score for each subject-grade combination.
course_tidy |>
group_by(year, subject) |>
summarise(avg_score = mean(average))
# Determine the distribution of letter grades for each subject.
table(course_tidy$subject, course_tidy$letter)
# Compute a GPA for each student using the scale F=0, D=1, C=2, B=3, A=4 across all of their letter-grade observations.
course_tidy |>
mutate(GPA = ifelse(letter == "A", 4,
ifelse(letter == "B", 3,
ifelse(letter == "C", 2,
ifelse(letter == "D", 1, 0))))) |>
group_by(student) |>
summarise(GPA = mean(GPA))
# If a student needs at least a 2.0 GPA to graduate, how many students would graduate?
course_tidy |>
mutate(GPA = ifelse(letter == "A", 4,
ifelse(letter == "B", 3,
ifelse(letter == "C", 2,
ifelse(letter == "D", 1, 0))))) |>
group_by(student) |>
summarise(GPA = mean(GPA)) |>
summarise(Above_2_count = sum(GPA > 2),
Above_2_prop = mean(GPA > 2))
# If a student needs at least a 2.0 GPA to graduate, how many students would graduate?
course_tidy |>
mutate(GPA = ifelse(letter == "A", 4,
ifelse(letter == "B", 3,
ifelse(letter == "C", 2,
ifelse(letter == "D", 1, 0))))) |>
group_by(student) |>
summarise(GPA = mean(GPA)) |>
summarise(Above_2_count = sum(GPA > 2),
Above_2_prop = mean(GPA > 2))
#Identify the student with the largest absolute difference between their average English score and average Math score.
course_tidy |>
group_by(student, subject) |>
summarise(avg_score = mean(average)) |>
pivot_wider(names_from=subject, values_from=avg_score) |>
mutate(diff = abs(Math - English)) |>
arrange(desc(diff))
#Create a visualization that compares numeric scores across grade levels and subjects.
course_tidy |>
mutate(year = factor(year, levels=c("Freshman", "Sophomore", "Junior", "Senior"))) |>
group_by(year, subject) |>
summarise(avg_score = mean(average)) |>
ggplot(aes(x=year, y=avg_score, fill=year)) +
geom_col() +
facet_grid(subject ~ .) +
geom_text(aes(label=round(avg_score, 2)), vjust=1.2) +
labs(title = "Column Chart for Average Score per Subject by Grade") +
theme(legend.position = "none",
plot.title = element_text(hjust=0.5))
# Using the county_complete dataset in the usdata library (and only looking at state, county, and pop columns), tidy the population data so that year is treated as a variable rather than being embedded in the column names. Then answer the following questions.
county_tidy <- county_complete |>
select(state, name, contains("pop")) |>
pivot_longer(contains("pop"), names_to="Year", values_to = "Population") |>
mutate(Year = sub("pop", "", Year),
Year = sub("_", "", Year))
# Determine the total U.S. county-level population in each available year.
county_tidy |>
group_by(Year) |>
summarise(n=sum(!is.na(Population)), Total_Pop = sum(Population, na.rm=TRUE))
# Determine the total U.S. county-level population in each available year.
county_tidy |>
group_by(Year) |>
summarise(n=sum(!is.na(Population)), Total_Pop = sum(Population, na.rm=TRUE))
# For each county, determine the absolute population change from 2000 to 2019 and identify the 10 counties with the largest increase.
county_tidy |>
filter(Year %in% c(2000,2019)) |>
pivot_wider(names_from=Year, values_from=Population) |>
mutate(abs_change = `2019` - `2000`) |>
arrange(desc(abs_change))
# For each county, determine the percent population change from 2000 to 2019 and identify the 10 counties with the largest percent increase.
county_tidy |>
filter(Year %in% c(2000,2019)) |>
pivot_wider(names_from=Year, values_from=Population) |>
mutate(perc_change = (`2019` - `2000`)/`2000` * 100) |>
arrange(desc(perc_change))
# How many counties had population decline from 2010 to 2019?
county_tidy |>
filter(Year %in% c(2010,2019)) |>
pivot_wider(names_from=Year, values_from=Population) |>
mutate(abs_change = `2019` - `2000`) |>
summarise(total_decrease = sum(`2019` < `2000`, na.rm=TRUE),
prop_decrease = mean(`2019` < `2000`, na.rm=TRUE))
# How many counties had population decline from 2010 to 2019?
county_tidy |>
filter(Year %in% c(2010,2019)) |>
pivot_wider(names_from=Year, values_from=Population) |>
mutate(abs_change = `2019` - `2000`) |>
summarise(total_decrease = sum(`2019` < `2000`, na.rm=TRUE),
prop_decrease = mean(`2019` < `2000`, na.rm=TRUE))
# How many counties had population decline from 2010 to 2019?
county_tidy |>
filter(Year %in% c(2010,2019)) |>
pivot_wider(names_from=Year, values_from=Population) |>
mutate(abs_change = `2019` - `2010`) |>
summarise(total_decrease = sum(`2019` < `2010`, na.rm=TRUE),
prop_decrease = mean(`2019` < `2010`, na.rm=TRUE))
# Create a visualization using your tidied population data (from 2010-2019) that helps show how county populations changed over time. Your graph should make it easy to compare population trends across years for at least one meaningful grouping of counties or states
county_tidy |>
filter(state == "Maryland") |>
filter(Year != 2000) |>
group_by(name) |>
mutate(prev_pop = lag(Population),
per_increase = (Population - prev_pop)/prev_pop * 100) |>
filter(Year != 2010) |>
ggplot(aes(x = Year, y = name, fill = per_increase)) +
geom_tile() +
geom_text(aes(label = paste0(round(per_increase, 2),"%")), size = 3) +
scale_fill_steps2(
low = "red",
mid = "white",
high = "green",
midpoint = 0,
breaks = c(-1.5, -1, -0.5, 0, 0.5, 1, 2, 2.5),
limits = c(-1.5, 2.5)
) +
labs(title = "Percent Increase of Maryland Counties Over Time",
subtitle = "Done with a geom_tile and scale_fill_steps2() for color",
fill = "% Increase",
y="County") +
theme(plot.title = element_text(hjust=0.5),
plot.subtitle = element_text(hjust=0.5))
# Using the billboard dataset, tidy the data so that week number is stored as a variable and chart position is stored as a value.
billboard_tidy <- billboard |>
pivot_longer(wk1:wk76, names_to="Week", values_to="Position") |>
mutate(Week = as.numeric(sub("wk", "", Week)))
# For each song, determine the best chart position it ever reached.
billboard_tidy |>
group_by(track) |>
summarise(top_position = min(Position, na.rm=TRUE))
billboard_tidy |>
group_by(track) |>
slice_min(n=1, order_by=Position, with_ties = FALSE)
# Which artist had the most songs appear in the dataset?
billboard_tidy |>
group_by(artist, track) |>
summarise(n=n()) |>
group_by(artist) |>
summarise(n=n()) |>
arrange(desc(n))
billboard_tidy |>
distinct(artist, track) |>
count(artist, sort = TRUE)
# Determine how many weeks each song remained on the chart.
billboard_tidy |>
group_by(track) |>
summarise(total_num_weeks = sum(!is.na(Position))) |>
arrange(desc(total_num_weeks))
# Determine how many weeks each song remained on the chart.
billboard_tidy |>
group_by(track) |>
summarise(total_num_weeks = sum(!is.na(Position))) |>
arrange(desc(total_num_weeks))
# Among songs that reached the top 10 at some point, which song stayed on the chart the longest?
billboard_tidy |>
group_by(track) |>
summarise(total_num_weeks = sum(!is.na(Position)),
best_position = min(Position, na.rm=TRUE)) |>
filter(best_position <= 10) |>
arrange(desc(total_num_weeks))
# For each artist, determine their average best chart position across all of their songs.
billboard_tidy |>
group_by(artist, track) |>
summarise(best_position = min(Position, na.rm = TRUE)) |>
group_by(artist) |>
summarise(avg_best_position = mean(best_position)) |>
arrange(avg_best_position)
# For each artist, determine their average best chart position across all of their songs.
billboard_tidy |>
group_by(artist, track) |>
summarise(best_position = min(Position, na.rm = TRUE)) |>
group_by(artist) |>
summarise(n=n(), avg_best_position = mean(best_position)) |>
arrange(avg_best_position)
# For each artist, determine their average best chart position across all of their songs.
billboard_tidy |>
group_by(artist, track) |>
summarise(best_position = min(Position, na.rm = TRUE)) |>
group_by(artist) |>
summarise(n=n(), avg_best_position = mean(best_position)) |>
arrange(avg_best_position) |> filter(n > 1)
# Determine which song had the largest improvement from its first recorded chart position to its best chart position.
billboard_tidy |>
group_by(track) |>
summarise(first_position = Position[which.min(Week)],
best_position = min(Position, na.rm=TRUE)) |>
mutate(improvement = first_position - best_position) |>
arrange(desc(improvement))
# Create a visualization using your tidied billboard dataset that shows how chart position changes from week to week for the 5 songs that stayed on the chart the longest
songs <- billboard_tidy |>
group_by(track) |>
summarise(total_num_weeks = sum(!is.na(Position))) |>
slice_max(order_by = total_num_weeks, n = 5) |>
pull(track)
billboard_tidy |>
filter(track %in% songs) |>
ggplot(aes(x = Week, y = Position, color = track)) +
geom_point() +
geom_line() +
scale_y_reverse() +
xlim(1, 65) +
labs(title="Plot of Position for Songs on the chart the longest",
subtitle = "The scale_y_reverse flips the y-axis") +
theme(legend.position = "bottom",
plot.title = element_text(hjust=0.5),
plot.subtitle = element_text(hjust=0.5))
