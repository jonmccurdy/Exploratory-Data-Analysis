library(ggplot2)
library(dplyr)
library(tidyr)
library(patchwork) # For side-by-side plotting
# 1. Create Dummy Data
set.seed(42)
days <- 1:100
nvda_price <- 800 + cumsum(rnorm(100, mean = 0.5, sd = 5))
small_price <- 15 + cumsum(rnorm(100, mean = 0.01, sd = 0.2))
df <- data.frame(Day = days, NVDA = nvda_price, SmallCap = small_price)
# 2. "Before" Plot: Raw Scale
p1 <- df %>%
pivot_longer(cols = c(NVDA, SmallCap), names_to = "Stock", values_to = "Price") %>%
ggplot(aes(x = Day, y = Price, color = Stock)) +
geom_line(size = 1) +
scale_color_manual(values = c("#2E8B57", "#8E8E93")) + # Your Theme Colors
labs(title = "Before: Raw Price Scale",
subtitle = "SmallCap looks like a flat line",
y = "Price (USD)") +
theme_minimal() +
theme(legend.position = "none")
# 3. "After" Plot: Z-Score Normalized
# Formula: (x - mean) / sd
df_norm <- df %>%
mutate(NVDA = (NVDA - mean(NVDA)) / sd(NVDA),
SmallCap = (SmallCap - mean(SmallCap)) / sd(SmallCap))
p2 <- df_norm %>%
pivot_longer(cols = c(NVDA, SmallCap), names_to = "Stock", values_to = "ZScore") %>%
ggplot(aes(x = Day, y = ZScore, color = Stock)) +
geom_line(size = 1) +
geom_hline(yintercept = 0, linetype = "dashed", color = "black") +
scale_color_manual(values = c("#2E8B57", "#8E8E93")) +
labs(title = "After: Z-Score Normalized",
subtitle = "Both stocks are now comparable",
y = "Standard Deviations from Mean") +
theme_minimal()
# 4. Combine and Save for PowerPoint
combined_plot <- p1 + p2 +
plot_annotation(title = "Z-Score Normalization: Leveling the Playing Field",
theme = theme(plot.title = element_text(size = 18, face = "bold")))
# Save at the specific PPT ratio we discussed
ggsave("normalization_slide.png", combined_plot, width = 10, height = 5.63, dpi = 300)
combined_plot
