# Theoretical table
prop_theory <- tibble(
sample_size = c(1, 4, 10, 30, 200),
pop_proportion = p,
pop_sd = pop_sd_prop,
expected_sample_proportion = p,
expected_sample_sd = sqrt(p * (1 - p) / sample_size)
)
prop_theory
# Simulated sampling distributions
prop_n1 <- sampling_distribution(expensive, sample_size = 1, n_samples = 1000, FUN = mean)
prop_n4 <- sampling_distribution(expensive, sample_size = 4, n_samples = 1000, FUN = mean)
prop_n10 <- sampling_distribution(expensive, sample_size = 10, n_samples = 1000, FUN = mean)
prop_n30 <- sampling_distribution(expensive, sample_size = 30, n_samples = 1000, FUN = mean)
prop_n200 <- sampling_distribution(expensive, sample_size = 200, n_samples = 1000, FUN = mean)
# Simulation summary table
prop_sim_table <- tibble(
`n = 1` = prop_n1,
`n = 4` = prop_n4,
`n = 10` = prop_n10,
`n = 30` = prop_n30,
`n = 200` = prop_n200
) |>
summarise(
across(everything(),
list(
Mean = ~mean(.),
SD = ~sd(.)
))
)
prop_sim_table
# Histograms
prop_compare <- tibble(
`n = 1` = prop_n1,
`n = 4` = prop_n4,
`n = 10` = prop_n10,
`n = 30` = prop_n30,
`n = 200` = prop_n200
) |>
pivot_longer(everything(), names_to = "sample_size", values_to = "stat") |>
mutate(sample_size = factor(sample_size,
levels = c("n = 1", "n = 4", "n = 10", "n = 30", "n = 200")))
ggplot(prop_compare, aes(x = stat)) +
geom_histogram(bins = 30) +
facet_wrap(~ sample_size, scales = "free") +
labs(title = "Sampling Distribution of the Sample Proportion",
x = "Sample Proportion of Expensive City-Months",
y = "Count")
# Optional comparison table
prop_compare_table <- tibble(
sample_size = c(1, 4, 10, 30, 200),
theoretical_mean = p,
simulated_mean = c(mean(prop_n1), mean(prop_n4), mean(prop_n10), mean(prop_n30), mean(prop_n200)),
theoretical_sd = sqrt(p * (1 - p) / c(1, 4, 10, 30, 200)),
simulated_sd = c(sd(prop_n1), sd(prop_n4), sd(prop_n10), sd(prop_n30), sd(prop_n200))
)
prop_compare_table
