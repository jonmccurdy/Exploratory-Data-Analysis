#install.packages("primes")
library(primes)
sum_primes_to_nth <- function(n){
primes <- list()
i = 2
if(n < 1){stop("n is not a positive whole number greater than 1")}
while(length(primes) < n){
if(is_prime(i) == TRUE){primes <- append(primes, i)}
i = i + 1
total_sum = sum(unlist(primes))
return(total_sum)}
}
sum_primes_to_nth(10)
sum_primes_to_nth(25)
houses_df <- house |> filter(np1 <= 38 & np1 >= 26)
houses_df <- houses_df |> arrange(np1)
houses_df <- houses_df |> select(congress,seats,p1,np1,p2,np2)
houses_df <- houses_df |> mutate(np_diff = (np2 - np1))
head(houses_df,10)
library(ggplot2)
ggplot(houses_df, aes(x = np1)) +
geom_boxplot(fill="lightblue") +
labs(title = "Boxplot of np1") +
scale_y_continuous(labels = NULL) +
theme(plot.title = element_text(hjust=0.4))
